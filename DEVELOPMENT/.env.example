# OpenAI — for regulatory intelligence AI parsing (V7 §4.3)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Contact form — destination email for form submissions
CONTACT_DESTINATION_EMAIL=joshua@synergisticinteraction.com.au

# Regulatory feed staging — Vercel KV (optional at launch, required for full pipeline)
# Get from: Vercel project dashboard → Storage → KV
KV_REST_API_URL=https://your-kv-url.kv.vercel-storage.com
KV_REST_API_TOKEN=your-token-here

# Site URL — used for canonical tags and hreflang
NEXT_PUBLIC_SITE_URL=https://synergisticinteraction.com.au

# Analytics (optional) — Vercel Analytics is enabled by default via @vercel/analytics

# Vercel Cron secret — protects the ingest endpoint in production
CRON_SECRET=your-cron-secret-here
