# Site URL, used for canonical tags and hreflang
NEXT_PUBLIC_SITE_URL=https://synergisticinteraction.com.au

# Contact form, destination email for form submissions
CONTACT_DESTINATION_EMAIL=jt@synergisticinteraction.com.au

# Contact form, Resend API key (optional; submissions are logged if unset)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re-your-key-here

# On-site assistant, Anthropic API key (the assistant stays dormant if unset)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=
